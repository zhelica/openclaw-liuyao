{
    "source": "Zhou Yi (I Ching)",
    "description": "六十四卦卦辞全集",
    "hexagrams": [
      {
        "id": 1,
        "name": "乾",
        "pinyin": "qián",
        "symbol": "䷀",
        "gua_ci": "元亨利贞。"
      },
      {
        "id": 2,
        "name": "坤",
        "pinyin": "kūn",
        "symbol": "䷁",
        "gua_ci": "元亨，利牝马之贞。君子有攸往，先迷后得主，利西南得朋，东北丧朋。安贞，吉。"
      },
      {
        "id": 3,
        "name": "屯",
        "pinyin": "zhūn",
        "symbol": "䷂",
        "gua_ci": "元亨利贞。勿用有攸往，利建侯。"
      },
      {
        "id": 4,
        "name": "蒙",
        "pinyin": "méng",
        "symbol": "䷃",
        "gua_ci": "亨。匪我求童蒙，童蒙求我。初噬告，再三渎，渎则不告。利贞。"
      },
      {
        "id": 5,
        "name": "需",
        "pinyin": "xū",
        "symbol": "䷄",
        "gua_ci": "有孚，光亨，贞吉。利涉大川。"
      },
      {
        "id": 6,
        "name": "讼",
        "pinyin": "sòng",
        "symbol": "䷅",
        "gua_ci": "有孚，窒。惕中吉。终凶。利见大人，不利涉大川。"
      },
      {
        "id": 7,
        "name": "师",
        "pinyin": "shī",
        "symbol": "䷆",
        "gua_ci": "贞，丈人，吉无咎。"
      },
      {
        "id": 8,
        "name": "比",
        "pinyin": "bǐ",
        "symbol": "䷇",
        "gua_ci": "吉。原筮元永贞，无咎。不宁方来，后夫凶。"
      },
      {
        "id": 9,
        "name": "小畜",
        "pinyin": "xiǎo xù",
        "symbol": "䷈",
        "gua_ci": "亨。密云不雨，自我西郊。"
      },
      {
        "id": 10,
        "name": "履",
        "pinyin": "lǚ",
        "symbol": "䷉",
        "gua_ci": "履虎尾，不咥人，亨。"
      },
      {
        "id": 11,
        "name": "泰",
        "pinyin": "tài",
        "symbol": "䷊",
        "gua_ci": "小往大来，吉亨。"
      },
      {
        "id": 12,
        "name": "否",
        "pinyin": "pǐ",
        "symbol": "䷋",
        "gua_ci": "否之匪人，不利君子贞，大往小来。"
      },
      {
        "id": 13,
        "name": "同人",
        "pinyin": "tóng rén",
        "symbol": "䷌",
        "gua_ci": "同人于野，亨。利涉大川，利君子贞。"
      },
      {
        "id": 14,
        "name": "大有",
        "pinyin": "dà yǒu",
        "symbol": "䷍",
        "gua_ci": "元亨。"
      },
      {
        "id": 15,
        "name": "谦",
        "pinyin": "qiān",
        "symbol": "䷎",
        "gua_ci": "亨，君子有终。"
      },
      {
        "id": 16,
        "name": "豫",
        "pinyin": "yù",
        "symbol": "䷏",
        "gua_ci": "利建侯行师。"
      },
      {
        "id": 17,
        "name": "随",
        "pinyin": "suí",
        "symbol": "䷐",
        "gua_ci": "元亨利贞，无咎。"
      },
      {
        "id": 18,
        "name": "蛊",
        "pinyin": "gǔ",
        "symbol": "䷑",
        "gua_ci": "元亨，利涉大川。先甲三日，后甲三日。"
      },
      {
        "id": 19,
        "name": "临",
        "pinyin": "lín",
        "symbol": "䷒",
        "gua_ci": "元亨利贞。至于八月有凶。"
      },
      {
        "id": 20,
        "name": "观",
        "pinyin": "guān",
        "symbol": "䷓",
        "gua_ci": "盥而不荐，有孚颙若。"
      },
      {
        "id": 21,
        "name": "噬嗑",
        "pinyin": "shì hé",
        "symbol": "䷔",
        "gua_ci": "亨。利用狱。"
      },
      {
        "id": 22,
        "name": "贲",
        "pinyin": "bì",
        "symbol": "䷕",
        "gua_ci": "亨。小利有攸往。"
      },
      {
        "id": 23,
        "name": "剥",
        "pinyin": "bō",
        "symbol": "䷖",
        "gua_ci": "不利有攸往。"
      },
      {
        "id": 24,
        "name": "复",
        "pinyin": "fù",
        "symbol": "䷗",
        "gua_ci": "亨。出入无疾，朋来无咎。反复其道，七日来复，利有攸往。"
      },
      {
        "id": 25,
        "name": "无妄",
        "pinyin": "wú wàng",
        "symbol": "䷘",
        "gua_ci": "元亨利贞。其匪正有眚，不利有攸往。"
      },
      {
        "id": 26,
        "name": "大畜",
        "pinyin": "dà xù",
        "symbol": "䷙",
        "gua_ci": "利贞。不家食，吉。利涉大川。"
      },
      {
        "id": 27,
        "name": "颐",
        "pinyin": "yí",
        "symbol": "䷚",
        "gua_ci": "贞吉。观颐，自求口实。"
      },
      {
        "id": 28,
        "name": "大过",
        "pinyin": "dà guò",
        "symbol": "䷛",
        "gua_ci": "栋桡，利有攸往，亨。"
      },
      {
        "id": 29,
        "name": "坎",
        "pinyin": "kǎn",
        "symbol": "䷜",
        "gua_ci": "习坎，有孚，维心亨，行有尚。"
      },
      {
        "id": 30,
        "name": "离",
        "pinyin": "lí",
        "symbol": "䷝",
        "gua_ci": "利贞，亨。畜牝牛，吉。"
      },
      {
        "id": 31,
        "name": "咸",
        "pinyin": "xián",
        "symbol": "䷞",
        "gua_ci": "亨，利贞。取女吉。"
      },
      {
        "id": 32,
        "name": "恒",
        "pinyin": "héng",
        "symbol": "䷟",
        "gua_ci": "亨，无咎，利贞，利有攸往。"
      },
      {
        "id": 33,
        "name": "遁",
        "pinyin": "dùn",
        "symbol": "䷠",
        "gua_ci": "亨，小利贞。"
      },
      {
        "id": 34,
        "name": "大壮",
        "pinyin": "dà zhuàng",
        "symbol": "䷡",
        "gua_ci": "利贞。"
      },
      {
        "id": 35,
        "name": "晋",
        "pinyin": "jìn",
        "symbol": "䷢",
        "gua_ci": "康侯用锡马蕃庶，昼日三接。"
      },
      {
        "id": 36,
        "name": "明夷",
        "pinyin": "míng yí",
        "symbol": "䷣",
        "gua_ci": "利艰贞。"
      },
      {
        "id": 37,
        "name": "家人",
        "pinyin": "jiā rén",
        "symbol": "䷤",
        "gua_ci": "利女贞。"
      },
      {
        "id": 38,
        "name": "睽",
        "pinyin": "kuí",
        "symbol": "䷥",
        "gua_ci": "小事吉。"
      },
      {
        "id": 39,
        "name": "蹇",
        "pinyin": "jiǎn",
        "symbol": "䷦",
        "gua_ci": "利西南，不利东北。利见大人，贞吉。"
      },
      {
        "id": 40,
        "name": "解",
        "pinyin": "xiè",
        "symbol": "䷧",
        "gua_ci": "利西南。无所往，其来复吉。有攸往，夙吉。"
      },
      {
        "id": 41,
        "name": "损",
        "pinyin": "sǔn",
        "symbol": "䷨",
        "gua_ci": "有孚，元吉，无咎，可贞，利有攸往。曷之用？二簋可用享。"
      },
      {
        "id": 42,
        "name": "益",
        "pinyin": "yì",
        "symbol": "䷩",
        "gua_ci": "利有攸往，利涉大川。"
      },
      {
        "id": 43,
        "name": "夬",
        "pinyin": "guài",
        "symbol": "䷪",
        "gua_ci": "扬于王庭，孚号，有厉。告自邑，不利即戎。利有攸往。"
      },
      {
        "id": 44,
        "name": "姤",
        "pinyin": "gòu",
        "symbol": "䷫",
        "gua_ci": "女壮，勿用取女。"
      },
      {
        "id": 45,
        "name": "萃",
        "pinyin": "cuì",
        "symbol": "䷬",
        "gua_ci": "亨。王假有庙，利见大人，亨，利贞。用大牲吉，利有攸往。"
      },
      {
        "id": 46,
        "name": "升",
        "pinyin": "shēng",
        "symbol": "䷭",
        "gua_ci": "元亨，用见大人，勿恤，南征吉。"
      },
      {
        "id": 47,
        "name": "困",
        "pinyin": "kùn",
        "symbol": "䷮",
        "gua_ci": "亨，贞，大人吉，无咎。有言不信。"
      },
      {
        "id": 48,
        "name": "井",
        "pinyin": "jǐng",
        "symbol": "䷯",
        "gua_ci": "改邑不改井，无丧无得，往来井井。汔至，亦未繘井，羸其瓶，凶。"
      },
      {
        "id": 49,
        "name": "革",
        "pinyin": "gé",
        "symbol": "䷰",
        "gua_ci": "己日乃孚，元亨利贞，悔亡。"
      },
      {
        "id": 50,
        "name": "鼎",
        "pinyin": "dǐng",
        "symbol": "䷱",
        "gua_ci": "元吉，亨。"
      },
      {
        "id": 51,
        "name": "震",
        "pinyin": "zhèn",
        "symbol": "䷲",
        "gua_ci": "亨。震来虩虩，笑言哑哑。震惊百里，不丧匕鬯。"
      },
      {
        "id": 52,
        "name": "艮",
        "pinyin": "gèn",
        "symbol": "䷳",
        "gua_ci": "艮其背，不获其身，行其庭，不见其人，无咎。"
      },
      {
        "id": 53,
        "name": "渐",
        "pinyin": "jiàn",
        "symbol": "䷴",
        "gua_ci": "女归吉，利贞。"
      },
      {
        "id": 54,
        "name": "归妹",
        "pinyin": "guī mèi",
        "symbol": "䷵",
        "gua_ci": "征凶，无攸利。"
      },
      {
        "id": 55,
        "name": "丰",
        "pinyin": "fēng",
        "symbol": "䷶",
        "gua_ci": "亨，王假之，勿忧，宜日中。"
      },
      {
        "id": 56,
        "name": "旅",
        "pinyin": "lǚ",
        "symbol": "䷷",
        "gua_ci": "小亨，旅贞吉。"
      },
      {
        "id": 57,
        "name": "巽",
        "pinyin": "xùn",
        "symbol": "䷸",
        "gua_ci": "小亨，利有攸往，利见大人。"
      },
      {
        "id": 58,
        "name": "兑",
        "pinyin": "duì",
        "symbol": "䷹",
        "gua_ci": "亨，利贞。"
      },
      {
        "id": 59,
        "name": "涣",
        "pinyin": "huàn",
        "symbol": "䷺",
        "gua_ci": "亨。王假有庙，利涉大川，利贞。"
      },
      {
        "id": 60,
        "name": "节",
        "pinyin": "jié",
        "symbol": "䷻",
        "gua_ci": "亨。苦节不可贞。"
      },
      {
        "id": 61,
        "name": "中孚",
        "pinyin": "zhōng fú",
        "symbol": "䷼",
        "gua_ci": "豚鱼吉，利涉大川，利贞。"
      },
      {
        "id": 62,
        "name": "小过",
        "pinyin": "xiǎo guò",
        "symbol": "䷽",
        "gua_ci": "亨，利贞。可小事，不可大事。飞鸟遗之音，不宜上宜下，大吉。"
      },
      {
        "id": 63,
        "name": "既济",
        "pinyin": "jì jì",
        "symbol": "䷾",
        "gua_ci": "亨，小利贞，初吉终乱。"
      },
      {
        "id": 64,
        "name": "未济",
        "pinyin": "wèi jì",
        "symbol": "䷿",
        "gua_ci": "亨，小狐汔济，濡其尾，无攸利。"
      }
    ]
  }